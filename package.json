{
  "name": "dadaia-pi-workspace",
  "version": "0.2.0",
  "description": "Python-first Pi-native SDD workspace manager for Spec Context Projects.",
  "type": "module",
  "license": "MIT",
  "keywords": [
    "pi-package",
    "pi",
    "sdd",
    "workspace",
    "spec-driven-development"
  ],
  "bin": {
    "dadaia-pi": "./bin/dadaia-pi.mjs"
  },
  "exports": {
    ".": "./dist/src/index.js"
  },
  "files": [
    "dist/src/",
    "src/dadaia_pi/",
    "pyproject.toml",
    "bin/",
    "extensions/",
    "skills/",
    "prompts/",
    "README.md",
    "CHANGELOG.md",
    "RELEASE_NOTES.md",
    "docs/",
    "scripts/governance-v1-smoke.mjs",
    "workflows/",
    "AGENTS.md",
    "LICENSE"
  ],
  "pi": {
    "extensions": [
      "./extensions"
    ],
    "skills": [
      "./skills"
    ],
    "prompts": [
      "./prompts"
    ]
  },
  "scripts": {
    "clean": "node scripts/clean.mjs",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "node scripts/lint.mjs",
    "test": "npm run build && node --test dist/tests/**/*.test.js",
    "test:python": "python3 -m pytest tests_py",
    "check:python": "PYTHONPATH=src python3 -m dadaia_pi specs doctor --specs-dir specs --json && python3 -m pytest tests_py",
    "check": "npm run lint && npm run typecheck && npm test && npm run check:python",
    "smoke:governance-v1": "npm run build && node scripts/governance-v1-smoke.mjs"
  },
  "engines": {
    "node": ">=20"
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-agent-core": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "typebox": "*"
  },
  "peerDependenciesMeta": {
    "@earendil-works/pi-ai": {
      "optional": true
    },
    "@earendil-works/pi-agent-core": {
      "optional": true
    },
    "@earendil-works/pi-coding-agent": {
      "optional": true
    },
    "@earendil-works/pi-tui": {
      "optional": true
    },
    "typebox": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.0"
  }
}
